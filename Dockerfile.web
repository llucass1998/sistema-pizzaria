# Estagio de build
FROM node:22-alpine AS builder

WORKDIR /app

# Copiar configuracoes e dependencias
COPY package.json package-lock.json ./
RUN npm ci --legacy-peer-deps

# Copiar codigo fonte e configuracoes (Vite, Tailwind, etc.)
COPY . .

# Fazer o build de producao via Vite
RUN npm run build

# Estagio de Nginx (servidor web e reverse proxy)
FROM nginx:alpine

# Copiar os arquivos estaticos construidos
COPY --from=builder /app/dist /usr/share/nginx/html

# Copiar a configuracao customizada do Nginx
COPY nginx.conf /etc/nginx/conf.d/default.conf

# Expor porta 80
EXPOSE 80

