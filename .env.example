DATABASE_URL="postgresql://usuario:senha@localhost:5432/pizzaria?schema=public"
PORT=3000
ADMIN_SESSION_SECRET="troque-essa-chave"
VITE_API_URL="http://localhost:3000/api"

# URL publica usada para retorno de checkout e webhooks.
# Em producao, use o dominio HTTPS da loja/plataforma.
PUBLIC_URL="http://localhost:5173"

# Pagamentos online.
# Valores aceitos: MOCK ou MERCADOPAGO.
# MOCK deve ser usado apenas em desenvolvimento/demonstracao.
PAYMENT_GATEWAY="MOCK"
PAYMENT_ALLOW_MOCK="false"
PAYMENT_ALLOW_MOCK_WEBHOOKS="false"
ENABLE_ONLINE_PIX="false"

# Mercado Pago sandbox/producao.
# Nunca exponha esses valores no frontend.
MERCADOPAGO_ENVIRONMENT="sandbox"
MERCADOPAGO_ACCESS_TOKEN=""
MERCADOPAGO_WEBHOOK_SECRET=""
# Opcional: sobrescreve a URL de notificacao enviada ao Mercado Pago.
MERCADOPAGO_WEBHOOK_URL=""

# Fiscal.
# MOCK registra apenas demonstracao interna; nao emite NFC-e real nem gera XML/PDF SEFAZ.
FISCAL_PROVIDER="MOCK"
